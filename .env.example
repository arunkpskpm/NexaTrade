# ──────────────────────────────────────────────────────────────
# NexaTrade — Environment Variables Template
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
APP_NAME=NexaTrade
APP_VERSION=1.0.0
APP_ENV=development                     # development | staging | production
DEBUG=false
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR

# ── Trading Mode ──────────────────────────────────────────────
ACTIVE_BROKER=paper                     # paper | breeze
TRADING_MODE=paper                      # paper | live

# ── API Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ── Security ──────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_SECRET_KEY=another-long-random-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=nexatrade
POSTGRES_PASSWORD=nexatrade_password
POSTGRES_DB=nexatrade_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── InfluxDB ──────────────────────────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=nexatrade-influx-token
INFLUX_ORG=nexatrade
INFLUX_BUCKET=market_data

# ── ICICI Breeze Connect ──────────────────────────────────────
# Leave blank when using paper trading mode
BREEZE_API_KEY=
BREEZE_API_SECRET=
BREEZE_SESSION_TOKEN=

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]